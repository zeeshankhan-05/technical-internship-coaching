---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  id?: string;
}

const { title, subtitle, align = 'left', id } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto' : '';
---

<div class={`max-w-3xl ${alignClass}`} id={id}>
  <h2 class="text-heading">{title}</h2>
  {subtitle && <p class="mt-4 text-lg text-text-muted">{subtitle}</p>}
</div>

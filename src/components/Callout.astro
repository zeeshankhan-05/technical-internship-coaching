---
interface Props {
  variant?: 'default' | 'info' | 'warning';
}

const { variant = 'default' } = Astro.props;

const variants = {
  default: 'border-border bg-accent-light/50',
  info: 'border-accent/30 bg-accent-light/30',
  warning: 'border-amber-300 bg-amber-50',
};
---

<aside class={`rounded-xl border p-5 ${variants[variant]}`}>
  <slot />
</aside>

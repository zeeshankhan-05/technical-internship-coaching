---
interface Props {
  variant?: 'default' | 'info' | 'warning';
}

const { variant = 'default' } = Astro.props;

const variants = {
  default: 'border-border bg-surface-raised',
  info: 'border-accent/40 bg-accent-light/60',
  warning: 'border-warning-border/50 bg-warning-bg/80 text-text',
};
---

<aside class={`rounded-xl border p-5 ${variants[variant]}`}>
  <slot />
</aside>

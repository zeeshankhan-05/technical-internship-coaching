---
import { siteConfig } from '../config/site';

interface Props {
  variant?: 'button' | 'text';
  class?: string;
}

const { variant = 'button', class: className = '' } = Astro.props;
const showLinkedIn = !siteConfig.linkedinUrl.includes('PLACEHOLDER');
---

{
  showLinkedIn && variant === 'button' && (
    <a
      href={siteConfig.linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={`btn btn-secondary text-sm ${className}`}
    >
      View my LinkedIn
    </a>
  )
}
{
  showLinkedIn && variant === 'text' && (
    <a
      href={siteConfig.linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={`text-sm font-semibold text-heading no-underline hover:text-accent ${className}`}
    >
      Connect on LinkedIn →
    </a>
  )
}

---
import { journeySteps } from '../data/homepage';
---

<div class="card bg-background" role="img" aria-label="Recruiting journey: technical work, clearer positioning, focused applications, interview preparation">
  <div class="space-y-6">
    {journeySteps.map((step, index) => (
      <div class="flex items-start gap-4">
        <div class="flex flex-col items-center">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent text-sm font-semibold text-white">
            {index + 1}
          </div>
          {index < journeySteps.length - 1 && (
            <div class="mt-2 h-8 w-0.5 bg-border-strong" aria-hidden="true"></div>
          )}
        </div>
        <div class="pt-1.5">
          <p class="font-semibold text-heading">{step.label}</p>
          <p class="text-sm text-text-muted">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
  <p class="mt-6 border-t border-border pt-4 text-xs text-text-muted">
    A structured approach to presenting your work — not a guarantee of interviews or offers.
  </p>
</div>

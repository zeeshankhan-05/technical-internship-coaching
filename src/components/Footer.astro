---
import { footerNav } from '../data/navigation';
import { siteConfig } from '../config/site';
import Disclaimer from './Disclaimer.astro';

const year = new Date().getFullYear();
const showEmail = !siteConfig.contactEmail.includes('PLACEHOLDER');
---

<footer class="border-t border-border bg-surface section-padding !py-12">
  <div class="container-page">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      <div>
        <p class="font-semibold text-heading">{siteConfig.siteName}</p>
        <p class="mt-2 text-sm text-text-muted">{siteConfig.supportingStatement}</p>
      </div>

      <nav aria-label="Footer navigation">
        <p class="text-sm font-semibold text-heading">Pages</p>
        <ul class="mt-3 space-y-2">
          {footerNav.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-text-muted no-underline hover:text-accent">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <p class="text-sm font-semibold text-heading">Contact</p>
        {showEmail ? (
          <p class="mt-3">
            <a href={`mailto:${siteConfig.contactEmail}`} class="text-sm no-underline">
              {siteConfig.contactEmail}
            </a>
          </p>
        ) : (
          <p class="mt-3 text-sm text-text-muted">
            Use the <a href="/apply" class="no-underline">intake form</a> to get in touch.
          </p>
        )}
        {!siteConfig.linkedinUrl.includes('PLACEHOLDER') && (
          <p class="mt-2">
            <a
              href={siteConfig.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm no-underline"
            >
              LinkedIn
            </a>
          </p>
        )}
      </div>
    </div>

    <div class="mt-10 border-t border-border pt-8">
      <Disclaimer />
      <p class="mt-4 text-xs text-text-muted">
        &copy; {year} {siteConfig.founderName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

---
import { footerNav } from '../data/navigation';
import { siteConfig } from '../config/site';
import Disclaimer from './Disclaimer.astro';
import LinkedInButton from './LinkedInButton.astro';

const year = new Date().getFullYear();
const showEmail = !siteConfig.contactEmail.includes('PLACEHOLDER');
---

<footer class="border-t border-border bg-surface py-10">
  <div class="container-page">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-sm">
        <p class="text-base font-semibold text-heading">{siteConfig.founderName}</p>
        <p class="mt-2 text-sm text-text-muted">Technical internship coaching for students.</p>
        <div class="mt-4">
          <LinkedInButton variant="text" />
        </div>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-5 gap-y-2">
          {footerNav.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-text-muted no-underline hover:text-accent">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="text-sm text-text-muted">
        {showEmail ? (
          <a href={`mailto:${siteConfig.contactEmail}`} class="no-underline hover:text-accent">{siteConfig.contactEmail}</a>
        ) : (
          <a href="#apply" class="no-underline hover:text-accent">Apply for a free call</a>
        )}
      </div>
    </div>

    <div class="mt-8 border-t border-border pt-6">
      <Disclaimer />
      <p class="mt-3 text-xs text-text-muted">&copy; {year} {siteConfig.founderName}</p>
    </div>
  </div>
</footer>

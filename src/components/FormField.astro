---
interface Props {
  id: string;
  label: string;
  name: string;
  type?: 'text' | 'email' | 'url' | 'tel' | 'number' | 'date' | 'month' | 'file';
  required?: boolean;
  hint?: string;
  accept?: string;
  rows?: number;
  as?: 'input' | 'textarea' | 'select';
  options?: { value: string; label: string }[];
  placeholder?: string;
}

const {
  id,
  label,
  name,
  type = 'text',
  required = false,
  hint,
  accept,
  rows = 4,
  as = type === 'file' ? 'input' : 'input',
  options = [],
  placeholder,
} = Astro.props;

const isTextarea = as === 'textarea';
const isSelect = as === 'select';
---

<div class="form-field">
  <label for={id} class="form-label">
    {label}
    {required && <span class="form-required" aria-hidden="true"> *</span>}
    {required && <span class="sr-only">(required)</span>}
  </label>

  {isTextarea ? (
    <textarea
      id={id}
      name={name}
      rows={rows}
      required={required}
      placeholder={placeholder}
      class="form-input"
      aria-describedby={hint ? `${id}-hint` : undefined}
    ></textarea>
  ) : isSelect ? (
    <select
      id={id}
      name={name}
      required={required}
      class="form-input"
      aria-describedby={hint ? `${id}-hint` : undefined}
    >
      {options.map((opt) => (
        <option value={opt.value}>{opt.label}</option>
      ))}
    </select>
  ) : (
    <input
      id={id}
      name={name}
      type={type}
      required={required}
      accept={accept}
      placeholder={placeholder}
      class="form-input"
      aria-describedby={hint ? `${id}-hint` : undefined}
    />
  )}

  {hint && (
    <p id={`${id}-hint`} class="form-hint">{hint}</p>
  )}
  <p id={`${id}-error`} class="form-error hidden" role="alert"></p>
</div>

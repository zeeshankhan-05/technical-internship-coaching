---
import { freeCallBenefits } from '../data/homepage';
import BookButton from './BookButton.astro';
---

<section id="free-call" class="section-padding scroll-mt-20">
  <div class="container-narrow">
    <h2 class="text-heading">What you get on the free call</h2>
    <p class="mt-3 text-text-muted">
      No sales pitch required. Just useful feedback you can apply right away.
    </p>

    <ul class="mt-8 space-y-5">
      {freeCallBenefits.map((item) => (
        <li class="flex gap-4">
          <span class="pain-dot mt-2" aria-hidden="true"></span>
          <div>
            <p class="font-semibold text-heading">{item.title}</p>
            <p class="mt-1 text-sm text-text-muted">{item.description}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="mt-10">
      <BookButton />
    </div>
  </div>
</section>

---
import FormField from './FormField.astro';
import ConsentField from './ConsentField.astro';
import { siteConfig } from '../config/site';
import { challengeOptions } from '../data/homepage';

interface Props {
  formId?: string;
}

const { formId = 'intake-form-inline' } = Astro.props;
const id = (name: string) => `${formId}-${name}`;

const resumeHint = `PDF or DOCX, max ${siteConfig.resumeMaxSizeBytes / (1024 * 1024)} MB`;
const acceptTypes = siteConfig.resumeAcceptedExtensions.join(',');

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const intakeSubmitUrl = supabaseUrl ? `${supabaseUrl}/functions/v1/submit-intake` : '';
---

<form id={formId} class="space-y-6" novalidate data-intake-form>
  <p class="hidden" aria-hidden="true">
    <label>Don&apos;t fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </p>

  <fieldset class="space-y-5">
    <div class="grid gap-5 sm:grid-cols-2">
      <FormField id={id('full-name')} label="Full name" name="fullName" required />
      <FormField id={id('email')} label="Email" name="email" type="email" required />
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      <FormField id={id('school')} label="School" name="school" required placeholder="e.g. UIUC" />
      <FormField id={id('major')} label="Major" name="major" required placeholder="e.g. Computer Science" />
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      <FormField id={id('graduation-date')} label="Expected graduation" name="graduationDate" type="month" required hint="Month and year" />
      <FormField id={id('target-role')} label="Target role or role family" name="targetRole" required placeholder="e.g. software engineering intern" />
    </div>
    <FormField id={id('recruiting-season')} label="Recruiting season" name="recruitingSeason" required placeholder="e.g. Summer 2027" />
    <FormField
      id={id('biggest-challenge')}
      label="What is your biggest challenge right now?"
      name="biggestChallenge"
      as="select"
      required
      options={challengeOptions}
    />
    <FormField
      id={id('work-authorization')}
      label="Sponsorship requirement"
      name="workAuthorization"
      as="select"
      required
      options={[
        { value: '', label: 'Select one…' },
        { value: 'US citizen or permanent resident', label: 'US citizen or permanent resident' },
        { value: 'F-1 / OPT eligible', label: 'F-1 / OPT eligible' },
        { value: 'Requires sponsorship', label: 'Requires sponsorship' },
        { value: 'Prefer to discuss privately', label: 'Prefer to discuss privately' },
      ]}
    />
  </fieldset>

  <fieldset class="space-y-5 border-t border-border pt-6">
    <legend class="sr-only">Additional details</legend>
    <FormField id={id('linkedin')} label="LinkedIn (optional)" name="linkedinUrl" type="url" placeholder="https://linkedin.com/in/..." />
    <FormField
      id={id('resume')}
      label="Resume"
      name="resume"
      type="file"
      accept={acceptTypes}
      hint={resumeHint}
      required
    />

    <div id={id('ai-consent-section')}>
      <ConsentField
        id={id('ai-processing')}
        label="AI processing preference"
        name="aiProcessing"
        required
        hint="Choose whether third-party AI tools may assist with resume review."
      />
    </div>
  </fieldset>

  <div class="form-field border-t border-border pt-6">
    <label class="flex cursor-pointer items-start gap-3">
      <input type="checkbox" id={id('privacy-consent')} name="privacyConsent" value="consented" required class="mt-1 h-4 w-4 accent-accent" />
      <span class="text-sm text-text-muted">
        I have read the <a href="/privacy" class="text-accent no-underline">Privacy Policy</a> and consent to the collection of my information.
        <span class="form-required"> *</span>
      </span>
    </label>
    <p id={id('privacy-consent-error')} class="form-error hidden" role="alert"></p>
  </div>

  <div id={id('form-status')} class="hidden rounded-lg border p-4" role="alert"></div>

  <button type="submit" class="btn btn-primary w-full sm:w-auto" id={id('submit-button')}>
    {siteConfig.cta.submit}
  </button>
</form>

<script define:vars={{ maxSize: siteConfig.resumeMaxSizeBytes, acceptedExts: siteConfig.resumeAcceptedExtensions, intakeSubmitUrl, supabaseAnonKey }}>
  function showFieldError(form, idSuffix, message) {
    const err = form.querySelector(`[id$="-${idSuffix}-error"]`);
    if (err) {
      err.textContent = message;
      err.classList.remove('hidden');
    }
  }

  function validateIntakeForm(form) {
    let valid = true;

    form.querySelectorAll('[aria-invalid="true"]').forEach((el) => el.removeAttribute('aria-invalid'));
    form.querySelectorAll('.form-error').forEach((el) => {
      el.classList.add('hidden');
      el.textContent = '';
    });

    const requiredFields = [
      { name: 'fullName', idSuffix: 'full-name', message: 'Please enter your full name.' },
      { name: 'school', idSuffix: 'school', message: 'Please enter your school.' },
      { name: 'major', idSuffix: 'major', message: 'Please enter your major.' },
      { name: 'graduationDate', idSuffix: 'graduation-date', message: 'Please select your expected graduation date.' },
      { name: 'targetRole', idSuffix: 'target-role', message: 'Please enter your target role.' },
      { name: 'recruitingSeason', idSuffix: 'recruiting-season', message: 'Please enter your recruiting season.' },
    ];

    for (const field of requiredFields) {
      const input = form.querySelector(`[name="${field.name}"]`);
      const value = input?.value?.trim() ?? '';
      if (!value) {
        valid = false;
        input?.setAttribute('aria-invalid', 'true');
        showFieldError(form, field.idSuffix, field.message);
      }
    }

    const email = form.querySelector('input[name="email"]');
    const emailValue = email?.value?.trim() ?? '';
    if (!emailValue) {
      valid = false;
      email?.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'email', 'Please enter your email.');
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailValue)) {
      valid = false;
      email?.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'email', 'Please enter a valid email.');
    }

    const biggestChallenge = form.querySelector('select[name="biggestChallenge"]');
    if (!biggestChallenge?.value) {
      valid = false;
      biggestChallenge?.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'biggest-challenge', 'Please select your biggest challenge.');
    }

    const workAuthorization = form.querySelector('select[name="workAuthorization"]');
    if (!workAuthorization?.value) {
      valid = false;
      workAuthorization?.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'work-authorization', 'Please select your sponsorship requirement.');
    }

    const linkedin = form.querySelector('input[name="linkedinUrl"]');
    if (linkedin?.value && !/^https?:\/\/.+/i.test(linkedin.value)) {
      valid = false;
      linkedin.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'linkedin', 'Please enter a valid URL starting with http:// or https://.');
    }

    const resume = form.querySelector('input[name="resume"]');
    const resumeFile = resume?.files?.[0];
    if (!resumeFile) {
      valid = false;
      resume?.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'resume', 'Please upload your resume.');
    } else {
      const ext = '.' + resumeFile.name.split('.').pop()?.toLowerCase();
      if (!acceptedExts.includes(ext) || resumeFile.size > maxSize) {
        valid = false;
        resume?.setAttribute('aria-invalid', 'true');
        showFieldError(form, 'resume', 'Please upload a PDF or DOCX under 5 MB.');
      }
    }

    if (!form.querySelector('input[name="aiProcessing"]:checked')) {
      valid = false;
      const aiRadio = form.querySelector('input[name="aiProcessing"]');
      aiRadio?.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'ai-processing', 'Please choose an AI processing preference.');
    }

    const privacy = form.querySelector('input[name="privacyConsent"]');
    if (privacy && !privacy.checked) {
      valid = false;
      privacy.setAttribute('aria-invalid', 'true');
      showFieldError(form, 'privacy-consent', 'Please consent to the privacy policy.');
    }

    return { valid, privacy };
  }

  function initIntakeForms() {
    document.querySelectorAll('[data-intake-form]').forEach((formEl) => {
      const form = formEl;
      if (form.dataset.bound) return;
      form.dataset.bound = 'true';

      const submitButton = form.querySelector('button[type="submit"]');
      const status = form.querySelector('[id$="-form-status"]');

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (status) {
          status.classList.add('hidden');
          status.textContent = '';
        }

        const { valid, privacy } = validateIntakeForm(form);

        if (!valid) {
          if (status) {
            status.className = 'alert-error';
            status.textContent = 'Please complete all required fields below.';
            status.classList.remove('hidden');
          }
          const firstInvalid = form.querySelector('[aria-invalid="true"]');
          firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          if (firstInvalid instanceof HTMLElement) {
            firstInvalid.focus({ preventScroll: true });
          }
          return;
        }

        if (!intakeSubmitUrl || !supabaseAnonKey) {
          if (status) {
            status.className = 'alert-error';
            status.textContent = 'Form storage is not configured yet. Please try again later.';
            status.classList.remove('hidden');
          }
          return;
        }

        const formData = new FormData(form);
        if (privacy?.checked) {
          formData.set('privacyConsent', 'consented');
        }

        submitButton?.setAttribute('disabled', 'true');
        submitButton?.classList.add('opacity-70');

        try {
          const response = await fetch(intakeSubmitUrl, {
            method: 'POST',
            headers: {
              apikey: supabaseAnonKey,
              Authorization: `Bearer ${supabaseAnonKey}`,
            },
            body: formData,
          });

          if (!response.ok) {
            const payload = await response.json().catch(() => ({}));
            throw new Error(payload.error || 'Submission failed');
          }

          sessionStorage.setItem('showSchedule', '1');
          document.getElementById('application-modal')?.classList.add('hidden');
          document.body.style.overflow = '';
          window.location.href = '/#schedule';
        } catch (error) {
          if (status) {
            status.className = 'alert-error';
            status.textContent = error instanceof Error
              ? error.message
              : 'Something went wrong. Please try again.';
            status.classList.remove('hidden');
          }
        } finally {
          submitButton?.removeAttribute('disabled');
          submitButton?.classList.remove('opacity-70');
        }
      });
    });
  }

  initIntakeForms();
  document.addEventListener('astro:page-load', initIntakeForms);
</script>

---
interface Props {
  items?: { label: string; href: string }[];
}

const { items = [] } = Astro.props;
---

{items.length > 0 && (
  <nav aria-label="Breadcrumb" class="mb-8">
    <ol class="flex flex-wrap items-center gap-2 text-sm text-text-muted">
      <li>
        <a href="/" class="no-underline hover:text-accent">Home</a>
      </li>
      {items.map((item, index) => (
        <li class="flex items-center gap-2">
          <span aria-hidden="true">/</span>
          {index === items.length - 1 ? (
            <span aria-current="page" class="text-heading">{item.label}</span>
          ) : (
            <a href={item.href} class="no-underline hover:text-accent">{item.label}</a>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

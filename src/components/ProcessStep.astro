---
interface Props {
  step: number;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
---

<div class="relative flex gap-4">
  <div
    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-accent/40 bg-accent-light text-sm font-bold text-accent"
    aria-hidden="true"
  >
    {step}
  </div>
  <div>
    <h3 class="text-lg font-semibold text-heading">{title}</h3>
    <p class="mt-1 text-text-muted">{description}</p>
  </div>
</div>

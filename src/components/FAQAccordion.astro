---
interface Props {
  faqs: { id: string; question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<div class="divide-y divide-border rounded-2xl border border-border bg-surface" style="box-shadow: var(--shadow-card)">
  {faqs.map((faq) => (
    <div class="faq-item">
      <h3>
        <button
          type="button"
          class="faq-trigger flex w-full items-center justify-between gap-4 px-5 py-4 text-left text-base font-medium text-heading hover:bg-background"
          aria-expanded="false"
          aria-controls={`faq-panel-${faq.id}`}
          id={`faq-button-${faq.id}`}
        >
          <span>{faq.question}</span>
          <span class="faq-icon shrink-0 text-text-muted" aria-hidden="true">+</span>
        </button>
      </h3>
      <div
        id={`faq-panel-${faq.id}`}
        role="region"
        aria-labelledby={`faq-button-${faq.id}`}
        class="faq-panel hidden px-5 pb-4"
        hidden
      >
        <p class="text-text-muted">{faq.answer}</p>
      </div>
    </div>
  ))}
</div>

<script>
  function initFAQAccordion() {
    document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((trigger) => {
      if (trigger.dataset.bound) return;
      trigger.dataset.bound = 'true';
      trigger.addEventListener('click', () => {
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        const panel = document.getElementById(trigger.getAttribute('aria-controls') ?? '');
        const icon = trigger.querySelector('.faq-icon');
        trigger.setAttribute('aria-expanded', String(!expanded));
        if (panel) {
          panel.hidden = expanded;
          panel.classList.toggle('hidden', expanded);
        }
        if (icon) icon.textContent = expanded ? '+' : '−';
      });
    });
  }
  initFAQAccordion();
  document.addEventListener('astro:page-load', initFAQAccordion);
</script>

---
import { mainNav, headerCta } from '../data/navigation';
import { siteConfig } from '../config/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-border bg-surface/95 backdrop-blur-sm">
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" class="shrink-0 text-base font-semibold text-heading no-underline hover:text-accent">
      <span class="hidden sm:inline">{siteConfig.siteName}</span>
      <span class="sm:hidden">TI Coaching</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium no-underline',
            currentPath === item.href || currentPath.startsWith(item.href + '/')
              ? 'text-accent'
              : 'text-text-muted hover:text-accent',
          ]}
          aria-current={currentPath === item.href ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <a href={headerCta.href} class="btn btn-primary text-sm">
        {headerCta.label}
      </a>
    </div>

    <button
      type="button"
      id="mobile-menu-button"
      class="btn btn-ghost min-h-11 min-w-11 p-2 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-surface md:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <nav class="container-page flex flex-col gap-1 py-4" aria-label="Mobile navigation">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-3 py-3 text-base font-medium text-heading no-underline hover:bg-background"
        >
          {item.label}
        </a>
      ))}
      <a href={headerCta.href} class="btn btn-primary mt-2">
        {headerCta.label}
      </a>
    </nav>
  </div>
</header>

<script>
  function initMobileNav() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    if (!button || !menu) return;

    const menuLinks = menu.querySelectorAll('a');

    function openMenu() {
      menu.classList.remove('hidden');
      button.setAttribute('aria-expanded', 'true');
      button.setAttribute('aria-label', 'Close menu');
      document.body.style.overflow = 'hidden';
      menuLinks[0]?.focus();
    }

    function closeMenu() {
      menu.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
      button.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
      button.focus();
    }

    button.addEventListener('click', () => {
      const isOpen = button.getAttribute('aria-expanded') === 'true';
      if (isOpen) closeMenu();
      else openMenu();
    });

    menu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeMenu();
        return;
      }

      if (e.key === 'Tab') {
        const focusable = Array.from(menu.querySelectorAll('a, button'));
        const first = focusable[0] as HTMLElement;
        const last = focusable[focusable.length - 1] as HTMLElement;

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    menuLinks.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>

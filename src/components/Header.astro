---
import { mainNav } from '../data/navigation';
import { siteConfig } from '../config/site';
import BookButton from './BookButton.astro';
---

<header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" class="shrink-0 text-sm font-semibold text-heading no-underline sm:text-base">
      {siteConfig.brandLine}
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Main navigation">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-text-muted no-underline hover:text-accent"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden sm:block">
      <BookButton class="!min-h-10 !px-4 !py-2 !text-sm" />
    </div>

    <button
      type="button"
      id="mobile-menu-button"
      class="btn btn-ghost min-h-11 min-w-11 p-2 sm:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-background sm:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <nav class="container-page flex flex-col gap-1 py-4" aria-label="Mobile navigation">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-3 py-3 text-base font-medium text-heading no-underline hover:bg-surface"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-2">
        <BookButton class="w-full" />
      </div>
    </nav>
  </div>
</header>

<script>
  function initMobileNav() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    if (!button || !menu || button.dataset.bound) return;
    button.dataset.bound = 'true';

    const menuLinks = menu.querySelectorAll('a');

    function closeMenu() {
      menu.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
      button.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
    }

    function openMenu() {
      menu.classList.remove('hidden');
      button.setAttribute('aria-expanded', 'true');
      button.setAttribute('aria-label', 'Close menu');
      document.body.style.overflow = 'hidden';
    }

    button.addEventListener('click', () => {
      const isOpen = button.getAttribute('aria-expanded') === 'true';
      if (isOpen) closeMenu();
      else openMenu();
    });

    menuLinks.forEach((link) => link.addEventListener('click', closeMenu));

    menu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }

  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>

---
import { founderProofPoints } from '../config/site';
---

<section class="proof-strip" aria-label="Background highlights">
  <div class="container-page flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-text-muted">
    {founderProofPoints.map((point, index) => (
      <span class="inline-flex items-center gap-4">
        {index > 0 && <span class="hidden text-border-strong sm:inline" aria-hidden="true">·</span>}
        <span>{point}</span>
      </span>
    ))}
  </div>
</section>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const description = 'Redirecting to schedule your call.';
---

<BaseLayout title="Schedule Call" description={description} path="/apply/success" noindex={true} minimal={true}>
  <section class="section-padding">
    <div class="container-narrow text-center">
      <p class="text-text-muted">Redirecting to scheduling…</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  sessionStorage.setItem('showSchedule', '1');
  window.location.replace('/#schedule');
</script>

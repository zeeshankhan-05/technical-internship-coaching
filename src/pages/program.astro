---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAGroup from '../components/CTAGroup.astro';
import PricingCard from '../components/PricingCard.astro';
import Callout from '../components/Callout.astro';
import { siteConfig } from '../config/site';
import {
  programCorePromise,
  programSessions,
  suitableStudentProfile,
  qualificationRequirements,
  includedServices,
  excludedServices,
  studentResponsibilities,
  betweenSessionSupport,
  reschedulingPolicy,
  refundPrinciples,
  aiPolicy,
  paymentSchedule,
  programSummary,
} from '../data/program';

const description =
  'Six-session one-on-one program to strengthen your technical internship application, résumé positioning, application system, and interview preparation.';
---

<BaseLayout title="Program" description={description} path="/program">
  <section class="section-padding">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'Program', href: '/program' }]} />

      <h1 class="text-heading">{siteConfig.programName}</h1>
      <p class="prose-content mt-6 max-w-3xl text-lg">{programCorePromise}</p>

      <div class="mt-12 grid gap-8 lg:grid-cols-3">
        <div class="card">
          <p class="text-sm font-medium text-accent">Duration</p>
          <p class="mt-2 text-2xl font-semibold text-heading">{programSummary.duration}</p>
          <p class="mt-1 text-sm text-text-muted">{programSummary.completionWindow}</p>
        </div>
        <div class="card">
          <p class="text-sm font-medium text-accent">Sessions</p>
          <p class="mt-2 text-2xl font-semibold text-heading">{programSummary.sessions} × {programSummary.sessionLength} min</p>
          <p class="mt-1 text-sm text-text-muted">Private one-on-one coaching</p>
        </div>
        <div class="card">
          <p class="text-sm font-medium text-accent">Founding price</p>
          <p class="mt-2 text-2xl font-semibold text-heading">${programSummary.price}</p>
          <p class="mt-1 text-sm text-text-muted">Complete program, not hourly</p>
        </div>
      </div>

      <div class="mt-16">
        <SectionHeading title="Suitable student profile" />
        <ul class="prose-content mt-6">
          {suitableStudentProfile.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="mt-16">
        <SectionHeading title="Qualification requirements" />
        <ul class="prose-content mt-6">
          {qualificationRequirements.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="mt-16">
        <SectionHeading
          title="Six-session sequence"
          subtitle="The sequence is adapted when another bottleneck is more urgent."
        />
        <div class="mt-10 space-y-8">
          {programSessions.map((session) => (
            <article class="card">
              <h3 class="text-lg font-semibold text-heading">
                Session {session.number} — {session.title}
              </h3>
              <ul class="mt-4 space-y-2">
                {session.topics.map((topic) => (
                  <li class="flex gap-2 text-sm text-text-muted">
                    <span class="text-accent" aria-hidden="true">•</span>
                    <span>{topic}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-16 grid gap-12 lg:grid-cols-2">
        <div>
          <SectionHeading title="Included services" />
          <ul class="prose-content mt-6">
            {includedServices.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div>
          <SectionHeading title="Excluded services" />
          <ul class="prose-content mt-6">
            {excludedServices.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      <div class="mt-16">
        <SectionHeading title="Student responsibilities" />
        <ul class="prose-content mt-6">
          {studentResponsibilities.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="mt-16">
        <SectionHeading title="Between-session support" />
        <p class="prose-content mt-6">{betweenSessionSupport}</p>
      </div>

      <div class="mt-16">
        <SectionHeading title="Rescheduling policy" />
        <ul class="prose-content mt-6">
          {reschedulingPolicy.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="mt-16">
        <SectionHeading title="Pricing and payment schedule" />
        <PricingCard showPaymentPlan={true}>
          <ul class="mt-4 space-y-2 text-sm text-text-muted">
            <li>Full payment: {paymentSchedule.full}</li>
            <li>Payment plan: {paymentSchedule.plan}</li>
            <li>{paymentSchedule.terms}</li>
          </ul>
        </PricingCard>
      </div>

      <div class="mt-16">
        <SectionHeading title="Refund principles" />
        <ul class="prose-content mt-6">
          {refundPrinciples.map((item) => <li>{item}</li>)}
        </ul>
        <p class="mt-4 text-sm text-text-muted">
          These principles summarize the refund approach. See the <a href="/terms">Terms</a> page for full details. They do not replace professional legal advice.
        </p>
      </div>

      <div class="mt-16">
        <SectionHeading title="AI processing policy" />
        <ul class="prose-content mt-6">
          {aiPolicy.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <Callout variant="info" class="mt-16">
        <p class="text-sm text-text-muted">
          <strong class="text-heading">No guaranteed outcomes.</strong> Coaching helps you present your experience more clearly and build a structured recruiting approach. It does not guarantee interviews, offers, referrals, compensation, or sponsorship. Results depend on your effort, skills, preparation, eligibility, execution, and market conditions.
        </p>
      </Callout>

      <div class="mt-12">
        <CTAGroup
          primary={{ label: 'Apply for the Founding Pilot', href: '/apply' }}
          secondary={{ label: 'Book a Free Strategy Call', href: '/book', variant: 'secondary' }}
        />
      </div>
    </div>
  </section>
</BaseLayout>

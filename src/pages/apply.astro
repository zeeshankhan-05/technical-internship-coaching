---
import BaseLayout from '../layouts/BaseLayout.astro';

const description = 'Redirecting to application form.';
---

<BaseLayout title="Apply" description={description} path="/apply" noindex={true}>
  <section class="section-padding">
    <div class="container-narrow text-center">
      <p class="text-text-muted">Redirecting to the application form…</p>
      <a href="/#apply" class="btn btn-accent mt-6 no-underline">Continue</a>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace('/#apply');
</script>

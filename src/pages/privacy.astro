---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTAGroup from '../components/CTAGroup.astro';
import { siteConfig } from '../config/site';

const description = 'Privacy policy for Technical Internship Coaching with Zeeshan Khan.';
const showEmail = !siteConfig.contactEmail.includes('PLACEHOLDER');
---

<BaseLayout title="Privacy Policy" description={description} path="/privacy">
  <section class="section-padding">
    <div class="container-page max-w-3xl">
      <Breadcrumbs items={[{ label: 'Privacy Policy', href: '/privacy' }]} />

      <h1 class="text-heading">Privacy Policy</h1>
      <p class="prose-content mt-4 text-sm text-text-muted">Last updated: June 2026</p>

      <div class="prose-content mt-10">
        <p>
          This policy describes how {siteConfig.founderName} collects, uses, and protects information when you use the coaching website or submit an intake form. This service is independently operated and is not affiliated with any university or employer.
        </p>

        <h2>What information is collected</h2>
        <p>When you complete the intake form, we may collect:</p>
        <ul>
          <li>Name, email, school, degree, graduation date, and academic year</li>
          <li>Time zone, target roles, recruiting season, and preferred locations</li>
          <li>Work authorization or sponsorship information you choose to share</li>
          <li>LinkedIn, GitHub, or portfolio URLs</li>
          <li>Your résumé (PDF or DOCX upload)</li>
          <li>Recruiting activity estimates (applications, responses, assessments, interviews)</li>
          <li>Experience descriptions and coaching goals</li>
          <li>AI processing preference and privacy consent</li>
        </ul>
        <p>
          We do not collect Social Security numbers, identity documents, immigration records, financial credentials, passwords, or sensitive medical information through this form.
        </p>

        <h2>Why information is collected</h2>
        <p>Information is collected to:</p>
        <ul>
          <li>Review your background before a strategy call</li>
          <li>Determine whether coaching is a reasonable fit</li>
          <li>Provide personalized coaching when you enroll</li>
          <li>Communicate about scheduling, sessions, and program administration</li>
          <li>Honor your AI processing and privacy preferences</li>
        </ul>

        <h2>Form processing</h2>
        <p>
          Intake forms are processed through Netlify Forms. Submitted data is stored on Netlify&apos;s infrastructure and may trigger email notifications to the coach. See Netlify&apos;s privacy documentation for details on their data handling.
        </p>

        <h2>Scheduling</h2>
        <p>
          Strategy calls are scheduled through Calendly. When you book a call, Calendly collects scheduling information according to its own privacy policy. The coaching service does not control Calendly&apos;s data practices.
        </p>

        <h2>Payment processing</h2>
        <p>
          Payment processing may be added separately in the future. If so, payment details will be handled by the chosen payment provider and will not be stored on this website.
        </p>

        <h2>Third-party AI processing</h2>
        <p>
          With your consent, limited third-party AI tools may assist with reviewing coaching materials. Identifying information is removed where reasonably possible before AI use. You may opt out of third-party AI processing without affecting access to coaching or the price.
        </p>

        <h2>What we do not do</h2>
        <ul>
          <li>We do not sell client data.</li>
          <li>We do not record strategy or coaching calls by default.</li>
          <li>We do not use client materials publicly without separate written permission.</li>
        </ul>

        <h2>Data retention</h2>
        <p>
          Working résumé files are approximately removed or anonymized within 90 days after program completion, unless you request continued storage or grant case-study permission. Legally or financially required transaction records may be retained as needed.
        </p>

        <h2>Requesting deletion</h2>
        <p>
          You may request deletion of non-required materials
          {showEmail ? (
            <> by emailing <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>.</>
          ) : (
            <> through the contact method provided after launch.</>
          )}
          {' '}Reasonable requests will be honored unless retention is required for legal, financial, or dispute-resolution purposes.
        </p>

        <h2>Security limits</h2>
        <p>
          Email and online form transmission are not perfectly secure. While reasonable care is taken with client information, no method of electronic transmission or storage is guaranteed to be completely secure.
        </p>

        <h2>Changes</h2>
        <p>
          This policy may be updated as the service evolves. Material changes will be reflected on this page with an updated date.
        </p>
      </div>

      <div class="mt-12">
        <CTAGroup primary={{ label: 'Return Home', href: '/' }} />
      </div>
    </div>
  </section>
</BaseLayout>

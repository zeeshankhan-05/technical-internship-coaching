---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import FreeCallBenefits from '../components/FreeCallBenefits.astro';
import ApplyScheduleSection from '../components/ApplyScheduleSection.astro';
import FounderStory from '../components/FounderStory.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import ApplicationModal from '../components/ApplicationModal.astro';
import { siteConfig } from '../config/site';
import { faqs } from '../data/faqs';
import { homepageFaqIds } from '../data/homepage';

const description = siteConfig.supportingStatement;
const homepageFaqs = faqs.filter((f) => homepageFaqIds.includes(f.id));
---

<BaseLayout title={siteConfig.siteName} description={description} path="/">
  <LandingHero />
  <FreeCallBenefits />
  <ApplyScheduleSection />
  <FounderStory />

  <section id="faq" class="section-padding scroll-mt-20">
    <div class="container-narrow">
      <h2 class="text-heading">Common questions</h2>
      <p class="mt-3 text-text-muted">Straight answers—no inflated promises.</p>
      <div class="mt-8">
        <FAQAccordion faqs={homepageFaqs} />
      </div>
    </div>
  </section>

  <ApplicationModal />
</BaseLayout>
